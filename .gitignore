video_annotation_toolkit/

# Output data
output/
*.mp4
*.csv
*.log

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/

# macOS
.DS_Store
.AppleDouble
.LSOverride